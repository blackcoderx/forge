# Database
DATABASE_URL=sqlite:///./forge.db

# JWT — generate a strong random secret for production
JWT_SECRET=change-me-before-deploy-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=12

# Fernet key for encrypting Langflow passwords at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# CORS — set to your Netlify domain in production
FRONTEND_URL=http://localhost:4321
