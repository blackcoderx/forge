---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Forge — AI Hackathon Platform">
    <!-- ── Hero ─────────────────────────────────────────── -->
    <section class="hero">
        <div class="container hero-inner">
            <p class="hero-eyebrow">
                // KONOV ARHTECHTIST AI HACKATHON PLATFORM
            </p>
            <h1 class="hero-headline">
                <span class="line">BUILD.</span>
                <span class="line accent">DEPLOY.</span>
                <span class="line">COMPETE.</span>
            </h1>
            <p class="hero-sub">
                Ship AI agents in hours.<br />Compete with the best.
            </p>
            <div class="hero-cta">
                <a href="/login" class="btn btn-primary btn-lg"
                    >START HACKING →</a
                >
                <a href="/hackathons" class="btn btn-outline btn-lg"
                    >VIEW HACKATHONS</a
                >
            </div>
        </div>

        <!-- decorative grid lines -->
        <div class="hero-grid" aria-hidden="true">
            <div class="grid-line"></div>
            <div class="grid-line"></div>
            <div class="grid-line"></div>
        </div>
    </section>

    <!-- ── Section 01: Build ─────────────────────────────── -->
    <section class="feature-section section-white">
        <div class="container feature-inner">
            <div class="feature-number">01</div>
            <div class="feature-content">
                <h2 class="feature-title">BUILD</h2>
                <div class="feature-rule"></div>
                <p class="feature-body">
                    Spin up AI agents and bots using Langflow.<br />
                    No setup. No boilerplate. Just ideas.
                </p>
                <ul class="feature-list">
                    <li>// Pre-configured environment — ready on day one</li>
                    <li>// Drag-and-drop AI flow builder</li>
                    <li>// Connect LLMs, tools, and APIs visually</li>
                </ul>
            </div>
            <div class="feature-icon" aria-hidden="true">
                <svg
                    width="120"
                    height="120"
                    viewBox="0 0 120 120"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <rect
                        x="1"
                        y="1"
                        width="118"
                        height="118"
                        stroke="black"
                        stroke-width="2"></rect>
                    <text
                        x="12"
                        y="48"
                        font-family="monospace"
                        font-size="28"
                        font-weight="bold"
                        fill="black">&lt;/&gt;</text
                    >
                    <line
                        x1="12"
                        y1="64"
                        x2="108"
                        y2="64"
                        stroke="black"
                        stroke-width="2"></line>
                    <text
                        x="12"
                        y="88"
                        font-family="monospace"
                        font-size="13"
                        fill="#555">$ forge build</text
                    >
                </svg>
            </div>
        </div>
    </section>

    <!-- ── Section 02: Deploy ────────────────────────────── -->
    <section class="feature-section section-black">
        <div class="container feature-inner reverse">
            <div class="feature-number inv">02</div>
            <div class="feature-content inv">
                <h2 class="feature-title">DEPLOY</h2>
                <div class="feature-rule inv"></div>
                <p class="feature-body">
                    Your agent runs live in our hosted environment.<br />
                    Ship in minutes. Iterate in seconds.
                </p>
                <ul class="feature-list">
                    <li>// Instant deployment — no DevOps required</li>
                    <li>// Live endpoint for your agent</li>
                    <li>// Test and iterate in real time</li>
                </ul>
            </div>
            <div class="feature-icon" aria-hidden="true">
                <svg
                    width="120"
                    height="120"
                    viewBox="0 0 120 120"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <rect
                        x="1"
                        y="1"
                        width="118"
                        height="118"
                        stroke="white"
                        stroke-width="2"></rect>
                    <polyline
                        points="60,20 60,80"
                        stroke="#FF6B00"
                        stroke-width="3"></polyline>
                    <polyline
                        points="35,55 60,80 85,55"
                        stroke="#FF6B00"
                        stroke-width="3"
                        fill="none"></polyline>
                    <line
                        x1="20"
                        y1="100"
                        x2="100"
                        y2="100"
                        stroke="white"
                        stroke-width="2"></line>
                </svg>
            </div>
        </div>
    </section>

    <!-- ── Section 03: Compete ───────────────────────────── -->
    <section class="feature-section section-white">
        <div class="container feature-inner">
            <div class="feature-number">03</div>
            <div class="feature-content">
                <h2 class="feature-title">COMPETE</h2>
                <div class="feature-rule"></div>
                <p class="feature-body">
                    Judges review your live project.<br />
                    The best agent wins.
                </p>
                <ul class="feature-list">
                    <li>// Judged on innovation, execution &amp; impact</li>
                    <li>// Real-time scoring by expert judges</li>
                    <li>// Glory, bragging rights, and prizes</li>
                </ul>
            </div>
            <div class="feature-icon" aria-hidden="true">
                <svg
                    width="120"
                    height="120"
                    viewBox="0 0 120 120"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <rect
                        x="1"
                        y="1"
                        width="118"
                        height="118"
                        stroke="black"
                        stroke-width="2"></rect>
                    <path
                        d="M40 30 L60 20 L80 30 L80 65 Q60 85 60 85 Q60 85 40 65 Z"
                        stroke="black"
                        stroke-width="2"
                        fill="#FF6B00"></path>
                    <line
                        x1="50"
                        y1="88"
                        x2="70"
                        y2="88"
                        stroke="black"
                        stroke-width="2"></line>
                    <rect
                        x="44"
                        y="88"
                        width="32"
                        height="10"
                        stroke="black"
                        stroke-width="2"
                        fill="black"></rect>
                </svg>
            </div>
        </div>
    </section>

    <!-- ── CTA Banner ────────────────────────────────────── -->
    <section class="cta-banner">
        <div class="container cta-inner">
            <div class="cta-text">
                <p class="cta-eyebrow">// DON'T WAIT</p>
                <h2 class="cta-headline">READY TO HACK?</h2>
            </div>
            <a href="/login" class="btn btn-black btn-lg">START HACKING →</a>
        </div>
    </section>
</Layout>

<style>
    /* ── Hero ───────────────────────────────────────────── */
    .hero {
        position: relative;
        min-height: calc(100vh - 64px);
        display: flex;
        align-items: center;
        background-color: var(--color-bg);
        overflow: hidden;
        border-bottom: var(--border);
    }

    .hero-inner {
        position: relative;
        z-index: 1;
        padding-top: 5rem;
        padding-bottom: 5rem;
    }

    .hero-eyebrow {
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        color: var(--color-accent);
        margin-bottom: 1.5rem;
    }

    .hero-headline {
        display: flex;
        flex-direction: column;
        font-size: clamp(4rem, 12vw, 9rem);
        font-weight: 800;
        line-height: 0.95;
        letter-spacing: -0.03em;
        margin-bottom: 2rem;
    }

    .hero-headline .line {
        display: block;
    }

    .hero-headline .accent {
        color: var(--color-accent);
        -webkit-text-stroke: 0px;
    }

    .hero-sub {
        font-size: 1.125rem;
        font-weight: 400;
        line-height: 1.7;
        color: #444;
        margin-bottom: 2.5rem;
        max-width: 480px;
    }

    .hero-cta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    /* decorative grid */
    .hero-grid {
        position: absolute;
        inset: 0;
        display: flex;
        justify-content: flex-end;
        pointer-events: none;
        opacity: 0.04;
    }

    .grid-line {
        width: 1px;
        height: 100%;
        background-color: var(--color-border);
        margin-right: 15%;
    }

    /* ── Feature Sections ───────────────────────────────── */
    .feature-section {
        border-bottom: var(--border);
    }

    .section-white {
        background-color: var(--color-bg);
    }

    .section-black {
        background-color: var(--color-surface);
    }

    .feature-inner {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 4rem;
        align-items: center;
        padding-top: 5rem;
        padding-bottom: 5rem;
    }

    .feature-inner.reverse {
        direction: rtl;
    }

    .feature-inner.reverse > * {
        direction: ltr;
    }

    .feature-number {
        font-size: 6rem;
        font-weight: 800;
        color: #eee;
        line-height: 1;
        user-select: none;
    }

    .feature-number.inv {
        color: #222;
    }

    .feature-content {
        max-width: 480px;
    }

    .feature-content.inv {
        color: var(--color-text-inv);
    }

    .feature-title {
        font-size: 3rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
    }

    .feature-rule {
        width: 60px;
        height: 4px;
        background-color: var(--color-accent);
        margin-bottom: 1.25rem;
    }

    .feature-rule.inv {
        background-color: var(--color-accent);
    }

    .feature-body {
        font-size: 1.0625rem;
        line-height: 1.7;
        margin-bottom: 1.25rem;
        color: #555;
    }

    .feature-content.inv .feature-body {
        color: #aaa;
    }

    .feature-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.375rem;
    }

    .feature-list li {
        font-size: 0.8125rem;
        font-weight: 500;
        color: #888;
    }

    .feature-content.inv .feature-list li {
        color: #666;
    }

    .feature-icon {
        opacity: 0.85;
    }

    /* ── CTA Banner ─────────────────────────────────────── */
    .cta-banner {
        background-color: var(--color-accent);
        border-bottom: var(--border);
    }

    .cta-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        padding-top: 5rem;
        padding-bottom: 5rem;
        flex-wrap: wrap;
    }

    .cta-eyebrow {
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        color: rgba(0, 0, 0, 0.6);
        margin-bottom: 0.5rem;
    }

    .cta-headline {
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--color-text);
        line-height: 1;
    }

    /* ── Responsive ─────────────────────────────────────── */
    @media (max-width: 900px) {
        .feature-inner {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        .feature-number {
            font-size: 3rem;
        }
        .feature-inner.reverse {
            direction: ltr;
        }
        .feature-icon {
            display: none;
        }
        .cta-inner {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
