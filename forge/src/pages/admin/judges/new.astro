---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Add Judge — Admin" nav="admin">
  <div class="page">
    <div class="container">

      <a href="/admin/judges" class="back-link">← BACK TO JUDGES</a>

      <div class="page-header">
        <p class="page-eyebrow">// ADMIN</p>
        <h1 class="page-title">ADD JUDGE</h1>
      </div>

      <form class="admin-form" id="judge-form">
        <div class="form-section">
          <h2 class="form-section-title">JUDGE CREDENTIALS</h2>
          <p class="section-desc">The judge will use these to log in at <code>/judge/login</code>.</p>
          <div class="form-grid">
            <div class="input-group">
              <label class="input-label" for="username">USERNAME *</label>
              <input type="text" id="username" name="username" class="input" required
                placeholder="judge_01" autocomplete="off" autofocus />
            </div>
            <div class="input-group">
              <label class="input-label" for="password">PASSWORD *</label>
              <input type="text" id="password" name="password" class="input" required
                placeholder="judge1pass" autocomplete="new-password" />
              <p class="input-hint">Shown in plaintext for easy distribution.</p>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <div id="form-error" class="alert-error" style="display:none;"></div>
          <div id="form-success" class="alert-success" style="display:none;"></div>
          <button type="submit" id="submit-btn" class="btn btn-primary btn-lg">ADD JUDGE →</button>
          <a href="/admin/judges" class="btn btn-outline btn-lg">CANCEL</a>
        </div>
      </form>

    </div>
  </div>
</Layout>

<script>
  const form       = document.getElementById('judge-form') as HTMLFormElement;
  const submitBtn  = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorEl    = document.getElementById('form-error') as HTMLElement;
  const successEl  = document.getElementById('form-success') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'ADDING...';
    errorEl.style.display = 'none';
    successEl.style.display = 'none';

    const fd = new FormData(form);
    try {
      const res = await fetch('/api/admin/judges', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username: fd.get('username'), password: fd.get('password') }),
      });

      if (res.ok) {
        const data = await res.json();
        successEl.textContent = `JUDGE "${data.username}" CREATED. ADD ANOTHER OR GO BACK.`;
        successEl.style.display = 'block';
        form.reset();
        document.getElementById('username')?.focus();
      } else {
        const data = await res.json();
        errorEl.textContent = data.detail ?? 'FAILED TO ADD JUDGE.';
        errorEl.style.display = 'block';
      }
    } catch {
      errorEl.textContent = 'NETWORK ERROR — try again.';
      errorEl.style.display = 'block';
    }

    submitBtn.disabled = false;
    submitBtn.textContent = 'ADD JUDGE →';
  });
</script>

<style>
  .page { padding:3rem 0 5rem; min-height:calc(100vh - 64px - 56px); }
  .back-link { display:inline-block; font-size:.8125rem; font-weight:700; letter-spacing:.06em; color:#888; margin-bottom:2rem; text-decoration:none; }
  .back-link:hover { color:var(--color-accent); }
  .page-header { margin-bottom:2rem; }
  .page-eyebrow { font-size:.8125rem; font-weight:600; letter-spacing:.1em; color:var(--color-accent); margin-bottom:.375rem; }
  .page-title { font-size:3rem; font-weight:800; letter-spacing:-.02em; line-height:1; }
  .admin-form { display:flex; flex-direction:column; gap:2rem; max-width:600px; }
  .form-section { border:var(--border); padding:2rem; display:flex; flex-direction:column; gap:1.25rem; }
  .form-section-title { font-size:.875rem; font-weight:800; letter-spacing:.1em; padding-bottom:.75rem; border-bottom:var(--border); }
  .section-desc { font-size:.875rem; color:#666; }
  .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; }
  .input-hint { font-size:.75rem; color:#999; margin-top:.375rem; }
  .form-actions { display:flex; flex-direction:column; gap:1rem; }
  .form-actions > div:last-of-type { display:flex; gap:1rem; flex-wrap:wrap; }
  .alert-success { border:2px solid #00aa55; padding:.75rem 1rem; font-size:.875rem; font-weight:600; color:#00aa55; background:#f0fff8; }
  code { font-family:var(--font-mono); background:#f0f0f0; padding:.125rem .375rem; font-size:.875em; }
  @media (max-width:640px) { .form-grid { grid-template-columns:1fr; } }
</style>
