---
import Layout from '../../layouts/Layout.astro';

const API = import.meta.env.API_URL ?? 'http://localhost:8000';
const token = Astro.cookies.get('forge_token')?.value;

// If judge is assigned to a specific hackathon, redirect straight there
try {
  const meRes = await fetch(`${API}/api/auth/me`, {
    headers: { Authorization: `Bearer ${token}` },
  });
  if (meRes.ok) {
    const me = await meRes.json();
    if (me.hackathon_id) {
      return Astro.redirect(`/judge/${me.hackathon_id}`);
    }
  }
} catch {}

const statusFilter = Astro.url.searchParams.get('status') ?? 'current';

let hackathons: any[] = [];
let fetchError = false;

try {
  const res = await fetch(`${API}/api/hackathons?status=${statusFilter}`, {
    headers: { Authorization: `Bearer ${token}` },
  });
  if (res.ok) hackathons = await res.json();
  else fetchError = true;
} catch { fetchError = true; }

const tabs = [
  { label: 'CURRENT',  value: 'current'  },
  { label: 'UPCOMING', value: 'upcoming' },
  { label: 'ENDED',    value: 'ended'    },
];
---

<Layout title="Judge Portal — Forge" nav="judge">
  <div class="page">
    <div class="container">

      <div class="page-header">
        <div>
          <p class="page-eyebrow">// JUDGE PORTAL</p>
          <h1 class="page-title">HACKATHONS</h1>
        </div>
      </div>

      <div class="tab-bar">
        {tabs.map(tab => (
          <a href={`/judge?status=${tab.value}`} class={`tab${statusFilter === tab.value ? ' active' : ''}`}>
            {tab.label}
          </a>
        ))}
      </div>

      {fetchError && (
        <div class="alert-error" style="margin-top:2rem;">FAILED TO LOAD — please refresh.</div>
      )}

      {!fetchError && hackathons.length === 0 && (
        <div class="empty-state">
          <p class="empty-text">NO {statusFilter.toUpperCase()} HACKATHONS.</p>
        </div>
      )}

      {!fetchError && hackathons.length > 0 && (
        <div class="hackathon-grid">
          {hackathons.map((h: any) => (
            <div class="card hackathon-card">
              <div class="card-top">
                <div class="card-meta">
                  <span class={`badge badge-${h.status}`}>{h.status.toUpperCase()}</span>
                  <span class="card-dates">
                    {new Date(h.start_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                    {' — '}
                    {new Date(h.end_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                </div>
                <h2 class="card-title">{h.name}</h2>
                {h.theme && <p class="card-theme">// {h.theme}</p>}
                <p class="card-desc">{h.description}</p>
              </div>
              <div class="card-footer">
                <a href={`/judge/${h.id}`} class="btn btn-primary">ENTER →</a>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .page { padding: 3rem 0 5rem; min-height: calc(100vh - 64px - 56px); }
  .page-header { margin-bottom: 2rem; }
  .page-eyebrow { font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.1em; color: var(--color-accent); margin-bottom: 0.375rem; }
  .page-title { font-size: 3rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
  .tab-bar { margin-bottom: 2.5rem; }
  .tab { text-decoration: none; display: inline-block; }
  .empty-state { padding: 4rem 0; text-align: center; }
  .empty-text { font-size: 1.125rem; font-weight: 700; letter-spacing: 0.06em; color: #aaa; }
  .hackathon-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1.5rem; }
  .hackathon-card { display: flex; flex-direction: column; justify-content: space-between; gap: 1.5rem; padding: 1.75rem; }
  .card-top { display: flex; flex-direction: column; gap: 0.625rem; }
  .card-meta { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .card-dates { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.05em; color: #888; }
  .card-title { font-size: 1.375rem; font-weight: 800; letter-spacing: -0.01em; line-height: 1.2; }
  .card-theme { font-size: 0.8125rem; font-weight: 600; color: var(--color-accent); letter-spacing: 0.04em; }
  .card-desc { font-size: 0.9rem; line-height: 1.6; color: #555; }
  .card-footer { border-top: var(--border); padding-top: 1.25rem; }
</style>
