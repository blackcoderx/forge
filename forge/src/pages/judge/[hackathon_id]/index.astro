---
import Layout from '../../../layouts/Layout.astro';

const API = import.meta.env.API_URL ?? 'http://localhost:8000';
const token = Astro.cookies.get('forge_token')?.value;
const { hackathon_id } = Astro.params;

let hackathon: any = null;
let teams: any[] = [];
let scores: Record<string, any> = {};
let creds: Record<string, any> = {};
let fetchError = false;

try {
  const [hackRes, teamsRes] = await Promise.all([
    fetch(`${API}/api/hackathons/${hackathon_id}`, { headers: { Authorization: `Bearer ${token}` } }),
    fetch(`${API}/api/hackathons/${hackathon_id}/teams`, { headers: { Authorization: `Bearer ${token}` } }),
  ]);

  if (hackRes.ok) hackathon = await hackRes.json();
  if (teamsRes.ok) teams = await teamsRes.json();

  // Fetch scores + credentials for each team in parallel
  const extras = await Promise.all(teams.map(async (t: any) => {
    const [sr, cr] = await Promise.all([
      fetch(`${API}/api/scores/${t.id}?hackathon_id=${hackathon_id}`, { headers: { Authorization: `Bearer ${token}` } }),
      fetch(`${API}/api/judge/teams/${t.id}/credentials`, { headers: { Authorization: `Bearer ${token}` } }),
    ]);
    const score = sr.ok ? await sr.json() : null;
    const cred  = cr.ok  ? await cr.json()  : null;
    return { id: t.id, score, cred };
  }));

  for (const e of extras) {
    scores[e.id] = e.score;
    creds[e.id]  = e.cred;
  }
} catch { fetchError = true; }
---

<Layout title={hackathon ? `${hackathon.name} — Judge` : 'Judge'} nav="judge">
  <div class="page">
    <div class="container">

      <a href="/judge" class="back-link">← BACK TO HACKATHONS</a>

      {fetchError && (
        <div class="alert-error" style="margin-top:1rem;">FAILED TO LOAD — please refresh.</div>
      )}

      {hackathon && (
        <>
          <div class="page-header">
            <div>
              <p class="page-eyebrow">// JUDGING</p>
              <h1 class="page-title">{hackathon.name}</h1>
            </div>
            <a href={`/judge/${hackathon_id}/leaderboard`} class="btn btn-outline">
              LEADERBOARD →
            </a>
          </div>

          <p class="team-count">{teams.length} TEAM{teams.length !== 1 ? 'S' : ''} TO JUDGE</p>

          {teams.length === 0 ? (
            <div class="empty-state">
              <p class="empty-text">NO TEAMS ASSIGNED TO YOU YET.</p>
            </div>
          ) : (
            <div class="team-grid">
              {teams.map((team: any) => {
                const score = scores[team.id];
                const cred  = creds[team.id];
                const isScored = score && score.total != null;
                const langflowUrl = cred?.langflow_url || hackathon.langflow_url || '#';
                return (
                  <div class="team-card card">
                    <div class="card-top">
                      <div class="card-name-row">
                        <h2 class="card-team-name">{team.name}</h2>
                        {isScored
                          ? <span class="badge badge-scored">SCORED {score.total}/40</span>
                          : <span class="badge badge-pending">PENDING</span>
                        }
                      </div>

                      <div class="cred-section">
                        <p class="cred-title">LANGFLOW CREDENTIALS</p>
                        {cred ? (
                          <div class="cred-list">
                            <div class="cred-row">
                              <span class="cred-label">USER</span>
                              <span class="cred-value" data-cred-id={`u-${team.id}`}>{cred.langflow_username}</span>
                              <button class="copy-btn" data-target={`u-${team.id}`}>COPY</button>
                            </div>
                            <div class="cred-row">
                              <span class="cred-label">PASS</span>
                              <span class="cred-value" data-cred-id={`p-${team.id}`}>{cred.langflow_password}</span>
                              <button class="copy-btn" data-target={`p-${team.id}`}>COPY</button>
                            </div>
                          </div>
                        ) : (
                          <p class="cred-na">Credentials unavailable</p>
                        )}
                      </div>
                    </div>

                    <div class="card-actions">
                      <a
                        href={langflowUrl}
                        target="_blank"
                        rel="noopener"
                        class="btn btn-outline card-btn"
                      >
                        PROJECT →
                      </a>
                      <a
                        href={`/judge/${hackathon_id}/${team.id}`}
                        class="btn btn-primary card-btn"
                      >
                        {isScored ? 'EDIT SCORE →' : 'SCORE →'}
                      </a>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </>
      )}
    </div>
  </div>
</Layout>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const el = document.querySelector(`[data-cred-id="${targetId}"]`);
      const value = el?.textContent?.trim() ?? '';
      navigator.clipboard.writeText(value).then(() => {
        btn.textContent = 'COPIED!';
        setTimeout(() => { btn.textContent = 'COPY'; }, 2000);
      });
    });
  });
</script>

<style>
  .page { padding: 3rem 0 5rem; min-height: calc(100vh - 64px - 56px); }
  .back-link { display: inline-block; font-size: 0.8125rem; font-weight: 700; letter-spacing: 0.06em; color: #888; margin-bottom: 2rem; text-decoration: none; }
  .back-link:hover { color: var(--color-accent); }
  .page-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap; }
  .page-eyebrow { font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.1em; color: var(--color-accent); margin-bottom: 0.375rem; }
  .page-title { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
  .team-count { font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.06em; color: #888; margin-bottom: 1.5rem; }
  .empty-state { padding: 4rem 0; text-align: center; }
  .empty-text { font-size: 1.125rem; font-weight: 700; color: #aaa; }

  .team-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; }

  .team-card { display: flex; flex-direction: column; justify-content: space-between; gap: 1.5rem; padding: 1.75rem; }

  .card-top { display: flex; flex-direction: column; gap: 1.25rem; }

  .card-name-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem; flex-wrap: wrap; }
  .card-team-name { font-size: 1.25rem; font-weight: 800; letter-spacing: -0.01em; line-height: 1.2; }

  .cred-section { background: var(--color-surface, #f8f8f8); border: var(--border); padding: 1rem; }
  .cred-title { font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.1em; color: #999; margin-bottom: 0.75rem; }
  .cred-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .cred-row { display: flex; align-items: center; gap: 0.75rem; }
  .cred-label { font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.06em; color: #aaa; width: 36px; flex-shrink: 0; }
  .cred-value { font-family: var(--font-mono); font-size: 0.8125rem; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .cred-na { font-size: 0.8125rem; color: #aaa; }
  .copy-btn { font-family: var(--font-mono); font-size: 0.625rem; font-weight: 700; letter-spacing: 0.06em; padding: 0.2rem 0.5rem; border: 1px solid #ccc; background: transparent; color: #aaa; cursor: pointer; flex-shrink: 0; }
  .copy-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }

  .card-actions { display: flex; gap: 0.75rem; border-top: var(--border); padding-top: 1.25rem; }
  .card-btn { flex: 1; text-align: center; justify-content: center; }
</style>
